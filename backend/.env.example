SECRET_KEY=change-me-to-a-random-secret-key
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL
DB_ENGINE=django.db.backends.postgresql
DB_NAME=crprojetos
DB_USER=crprojetos
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=crprojetos
R2_PUBLIC_URL=

# AbacatePay (https://app.abacatepay.com/settings/keys)
ABACATEPAY_API_KEY=

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# Firebase Admin (caminho para o JSON da service account)
FIREBASE_SERVICE_ACCOUNT_PATH=

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:8080,http://localhost:8000,https://appcrprojetos.pages.dev
